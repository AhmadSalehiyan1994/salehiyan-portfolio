# Public website settings
NEXT_PUBLIC_SITE_URL=https://www.salehiyan.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Contact form options
# Static hosting: set an external endpoint such as Formspree
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Server hosting: enable the internal /api/contact route instead
NEXT_PUBLIC_CONTACT_USE_INTERNAL_API=false

# Optional backend/server features below
DATABASE_URL=postgres://username:password@localhost:5432/personal_website
AUTH_SECRET=change-me-to-a-long-random-secret
BOOTSTRAP_ADMIN_KEY=one-time-bootstrap-key

# Optional one-command admin bootstrap script
BOOTSTRAP_ADMIN_NAME=Your Name
BOOTSTRAP_ADMIN_EMAIL=you@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-password

# Optional alerting webhook
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
ALERT_RETRY_ATTEMPTS=3
ALERT_TIMEOUT_MS=5000
ALERT_DEDUP_WINDOW_MS=60000

# Optional retention policy for maintenance jobs
RETENTION_CLIENT_ERRORS_DAYS=30
RETENTION_CONTACT_SUBMISSIONS_DAYS=365
RETENTION_NOTIFICATIONS_DAYS=180
RETENTION_RATE_LIMIT_DAYS=30
RETENTION_ADMIN_AUDIT_DAYS=365
RETENTION_BACKEND_JOB_RUNS_DAYS=180
BACKEND_JOB_INTERVAL_MINUTES=60
